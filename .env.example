# ═══════════════════════════════════════════════════════════════════════════
# GridPulse environment — copy to .env and fill in
# ═══════════════════════════════════════════════════════════════════════════

# ── LLM provider (reuses the Project 2 abstraction) ───────────────────────
LLM_PROVIDER=openrouter
LLM_MODEL_OVERRIDE=nvidia/nemotron-3-super-120b-a12b:free
GROQ_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Kafka / Redpanda ─────────────────────────────────────────────────────
KAFKA_BOOTSTRAP=localhost:19092
KAFKA_TOPIC_EVENTS=grid_events
KAFKA_TOPIC_ANOMALIES=grid_anomalies
KAFKA_GROUP_ID=gridpulse

# ── Source data ───────────────────────────────────────────────────────────
# Can be a path to the Project 1 Gold Delta table, or an EIA CSV export.
REPLAY_SOURCE=../Nuevo proyecto/data/gold/load_features
REPLAY_REGION=CAL
REPLAY_SPEED=60           # 60x real time — 1 real second == 60 simulated seconds

# ── Anomaly detector (MLflow) ────────────────────────────────────────────
# Points at Project 1's local MLflow; override with Databricks UC path for cloud.
MLFLOW_TRACKING_URI=../Nuevo proyecto/mlruns
ANOMALY_MODEL=energy-anomaly-detector
ANOMALY_ALIAS=staging

# ── EnergyScholar RAG (Project 2) ────────────────────────────────────────
# If unset the agent's search_literature tool returns a "service unavailable".
ENERGYSCHOLAR_URL=http://localhost:8001

# ── Discord webhook for alerts ───────────────────────────────────────────
# Create a webhook in any Discord server: Channel Settings → Integrations →
# Webhooks → New Webhook → Copy Webhook URL. Paste it below.
DISCORD_WEBHOOK_URL=

# ── Paths ─────────────────────────────────────────────────────────────────
DELTA_PATH=./data/delta

# ── Agent behaviour ───────────────────────────────────────────────────────
AGENT_MAX_ITERATIONS=5
AGENT_COST_BUDGET_TOKENS=50000

# ── Langfuse tracing (optional) ───────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── API / UI ──────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8002
DASHBOARD_PORT=8503

LOG_LEVEL=INFO
